<?xml version="1.0" encoding="utf-8" ?>
<ContentPage x:Class="StarterApp.Views.NotificationPage"
             xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:StarterApp.ViewModels"
             Title="Notifications">

    <ContentPage.BindingContext>
        <vm:NotificationPageViewModel />
    </ContentPage.BindingContext>

    <ScrollView>
        <Grid Padding="30" RowSpacing="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <!-- Error Message -->
            <Border Grid.Row="0"
                    BackgroundColor="{AppThemeBinding Light=#FFEBEE, Dark=#1B0000}"
                    Stroke="{AppThemeBinding Light=#F44336, Dark=#EF5350}"
                    StrokeThickness="1"
                    Padding="15"
                    IsVisible="{Binding HasError}">
                <Border.StrokeShape>
                    <RoundRectangle CornerRadius="8" />
                </Border.StrokeShape>
                <Label Text="{Binding ErrorMessage}"
                       TextColor="{AppThemeBinding Light=#D32F2F, Dark=#EF5350}"
                       FontSize="14" />
            </Border>

            <!-- Main Content -->
            <StackLayout Grid.Row="1" 
                        Spacing="15">
                <!-- Name Entry -->
                <StackLayout>
                    <Label Text="Name" 
                           FontSize="14"
                           FontAttributes="Bold"
                           Margin="0,0,0,5" />
                    <Entry Text="{Binding NotificationName}"
                           Placeholder="Enter name..."
                           FontSize="16"
                           BackgroundColor="{AppThemeBinding Light=White, Dark={StaticResource Gray800}}" />
                </StackLayout>

                <!-- Message Entry -->
                <StackLayout>
                    <Label Text="Message"
                           FontSize="14"
                           FontAttributes="Bold"
                           Margin="0,0,0,5" />
                    <Entry Text="{Binding NotificationMessage}"
                           Placeholder="Enter message..."
                           FontSize="16"
                           BackgroundColor="{AppThemeBinding Light=White, Dark={StaticResource Gray800}}" />
                </StackLayout>
            </StackLayout>

            <!-- Send Button -->
            <Button Grid.Row="2"
                    Text="Send Notification"
                    Command="{Binding SendCommand}"
                    BackgroundColor="{AppThemeBinding Light={StaticResource Primary}, Dark={StaticResource PrimaryDark}}"
                    TextColor="White"
                    HeightRequest="50"
                    CornerRadius="8"
                    FontSize="16"
                    FontAttributes="Bold"
                    IsEnabled="true" />
        </Grid>
    </ScrollView>
</ContentPage>